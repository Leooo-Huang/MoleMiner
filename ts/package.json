{
  "name": "moleminer",
  "version": "0.3.0",
  "description": "AI-powered multi-source recursive search CLI",
  "type": "module",
  "bin": {
    "moleminer": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:web": "cd src/web/ui && npm run build",
    "build": "npm run build:web && esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --packages=external",
    "test": "vitest run",
    "dev": "vitest",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.4.0",
    "cheerio": "^1.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "defuddle": "^0.14.0",
    "jsdom": "^29.0.1",
    "ora": "^8.2.0",
    "qrcode": "^1.5.4",
    "sql.js": "^1.12.0"
  },
  "optionalDependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/sql.js": "^1.4.9",
    "esbuild": "^0.25.0",
    "msw": "^2.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "keywords": [
    "search",
    "ai",
    "llm",
    "cli",
    "multi-source",
    "recursive-search",
    "brave",
    "reddit",
    "hackernews",
    "github",
    "zhihu",
    "xiaohongshu"
  ],
  "author": "Leo-Cyberautonomy",
  "files": [
    "dist/",
    "scripts/"
  ],
  "license": "MIT"
}
